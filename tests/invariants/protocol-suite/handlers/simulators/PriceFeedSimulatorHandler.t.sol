pragma solidity ^0.8.19;

// Test Contracts
import {BaseHandler} from '../../base/BaseHandler.t.sol';
import {MockPriceFeedSimulator} from '../../../shared/mocks/MockPriceFeedSimulator.sol';

import 'forge-std/console.sol';

/// @title PriceFeedSimulatorHandler
/// @notice Handler test contract for a set of actions
contract PriceFeedSimulatorHandler is BaseHandler {
  ///////////////////////////////////////////////////////////////////////////////////////////////
  //                                      STATE VARIABLES                                      //
  ///////////////////////////////////////////////////////////////////////////////////////////////

  ///////////////////////////////////////////////////////////////////////////////////////////////
  //                                          ACTIONS                                          //
  ///////////////////////////////////////////////////////////////////////////////////////////////

  ///////////////////////////////////////////////////////////////////////////////////////////////
  //                                         OWNER ACTIONS                                     //
  ///////////////////////////////////////////////////////////////////////////////////////////////

  function setPrice(int256 price, uint8 i) public {
    address priceFeed = _getRandomPriceFeed(i);

    price = clampBetween(price, PRICE_MIN, PRICE_MAX);

    MockPriceFeedSimulator(priceFeed).setPrice(price);
  }

  ///////////////////////////////////////////////////////////////////////////////////////////////
  //                                           HELPERS                                         //
  ///////////////////////////////////////////////////////////////////////////////////////////////
}
